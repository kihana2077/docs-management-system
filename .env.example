# ========== MySQL 数据库连接配置 ==========
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=fastapi_db
DB_CHARSET=utf8mb4

# ========== SQLAlchemy 引擎配置 ==========
# 生产环境建议改为 false
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ========== 文件上传配置 ==========
UPLOAD_DIR=backend/uploads
