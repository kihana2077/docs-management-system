# ========== MySQL 数据库连接配置 ==========
# 数据库服务器地址
DB_HOST=localhost
# 数据库服务器端口（MySQL 默认为 3306）
DB_PORT=3306
# 数据库用户名
DB_USER=root
# 数据库用户密码（如果密码含特殊字符，确保不被 shell 解析）
DB_PASSWORD=password
# 数据库名称
DB_NAME=fastapi_db
# 字符集编码（推荐 utf8mb4，支持 emoji）
DB_CHARSET=utf8mb4

# ========== SQLAlchemy 引擎配置 ==========
# 是否打印 SQL 日志（生产环境建议改成 false）
DB_ECHO=true
# 连接池大小（同时保持的连接数）
DB_POOL_SIZE=10
# 连接池溢出数（超过池大小时额外允许的连接数）
DB_MAX_OVERFLOW=20

# ========== 文件上传配置 ==========
# 文件上传保存目录（相对于项目根目录）
UPLOAD_DIR=backend/uploads